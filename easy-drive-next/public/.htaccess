Options -MultiViews -Indexes
DirectorySlash Off
RewriteEngine On

# 1. Serve _next/ static assets directly (JS, CSS, fonts)
RewriteCond %{REQUEST_URI} ^/_next/
RewriteRule ^ - [L]

# 2. Serve real files directly (images, favicon, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3. Handle trailing slash: /about/ -> serve about.html directly (no redirect)
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.*)/$ /$1.html [L]

# 4. Handle clean URL: /about -> serve about.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

# 5. Custom 404
ErrorDocument 404 /404.html

# Security & SEO headers
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
